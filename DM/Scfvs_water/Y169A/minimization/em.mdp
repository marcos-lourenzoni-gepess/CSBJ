constraints         =  none

integrator          =  steep

dt                  =  0.002    ; ps !

nsteps              =  50000

nstlist             =  20

ns_type             =  grid

rlist               =  1.0

coulombtype         =  pme

rcoulomb            =  1.0

vdw-type            =  cut-off

rvdw                =  1.0

nstenergy           =  500

cutoff-scheme       =  verlet

;

;       Energy minimizing stuff

;

emtol               =  1000.0

emstep              =  0.01